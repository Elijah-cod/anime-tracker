{
  "name": "anime-tracker-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:typecheck": "npm --prefix frontend exec -- tsc --noEmit -p frontend/tsconfig.json",
    "backend:dev": "uvicorn app.main:app --reload --app-dir backend",
    "backend:test": "python -m pytest backend/tests",
    "backend:check": "python3 -m compileall backend/app",
    "deploy:check": "npm run backend:check && npm run frontend:build && npm run frontend:typecheck"
  }
}
